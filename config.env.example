# Hindsight LLM configuration.
# Used by start.sh (dev) and as the source of truth for launchd plist generation.
# The launchd service plist duplicates these values inline — regenerate the plist
# after changing this file (see INSTALL.md Step 5).

HINDSIGHT_API_PORT=8888
HINDSIGHT_API_LLM_PROVIDER=litellm
HINDSIGHT_API_LLM_MODEL=vertex_ai/claude-sonnet-4-6
HINDSIGHT_API_RETAIN_LLM_PROVIDER=litellm
HINDSIGHT_API_RETAIN_LLM_MODEL=vertex_ai/claude-haiku-4-5@20251001
VERTEXAI_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=global
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
HINDSIGHT_API_RERANKER_PROVIDER=local
